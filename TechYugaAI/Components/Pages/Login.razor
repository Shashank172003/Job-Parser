@page "/login"
@inject NavigationManager Nav

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Force full page reload behavior
        }
    }

    private void GoToGoogle()
    {
        Nav.NavigateTo("/google-login", forceLoad: true);
    }
}

<PageTitle>Login - TechYugaAI</PageTitle>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="auth-error">@errorMessage</div>
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">TechYuga<span>AI</span></div>
        <h2 class="auth-title">Welcome Back</h2>
        <p class="auth-subtitle">Sign in to your account</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="auth-error">@errorMessage</div>
        }

        <form method="post" action="/account/login" class="auth-form">
            <AntiforgeryToken />
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="you@example.com" class="form-input" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" class="form-input" />
            </div>
            <button type="submit" class="auth-btn">Sign In</button>

          

        </form>

        <div class="auth-divider"><span>or</span></div>

        <button type="button" class="auth-btn-google"
                onclick="window.location.href='/google-login'">
            <img src="https://www.google.com/favicon.ico" width="18" height="18" />
            Continue with Google
        </button>

        <p class="auth-switch">
            Don't have an account? <a href="/register">Create one</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? error { get; set; }
    private string errorMessage => error ?? "";
}